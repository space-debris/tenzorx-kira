# =============================================================================
# KIRA Backend — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# =============================================================================

# REQUIRED — Google Gemini Vision API (CV module)
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# NOT REQUIRED — Geo module uses OSM (Nominatim + Overpass), all free
# No Google Maps key needed anywhere in this project.

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=kira_db
POSTGRES_USER=kira_user
POSTGRES_PASSWORD=your_db_password_here

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG_MODE=true

# CORS configuration
# Comma-separated list of explicit origins. Example:
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://192.168.1.20:5173,https://your-frontend-domain.com
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Regex fallback for LAN-style origins in development.
# Set blank to disable.
CORS_ALLOW_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|0\.0\.0\.0|192\.168\.\d+\.\d+|10\.\d+\.\d+\.\d+|172\.(1[6-9]|2\d|3[0-1])\.\d+\.\d+)(:\d+)?$

# Set true only if you use cookie-based auth across origins.
CORS_ALLOW_CREDENTIALS=false

# Avoid enabling in production. If true, credentials are forced off.
CORS_ALLOW_ALL_ORIGINS=false

# Optional method/header restrictions (comma-separated). Keep * for simplicity.
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

LOG_LEVEL=INFO
